{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./src",
        "paths": {
            "app/*": [
                "app/*"
            ],
            "config/*": [
                "config/*"
            ],
            "core/*": [
                "app/core/*"
            ],
            "features/*": [
                "app/features/*"
            ],
            "types/*": [
                "types/*"
            ]
        }
    },
    "include": [
        "src/app/**/*",
        "src/types/**/*"
    ]
}