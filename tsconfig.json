        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./src/app",
        "paths": {
            "/*": [
                "./*"
            ]
        }
    },
    "include": [
        "src/app/**/*"
    ]
}